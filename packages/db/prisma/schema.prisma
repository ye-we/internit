// Prisma schema mirroring the Drizzle definitions in packages/db/src/schema.ts.
// This file is a reference/representation — the project's source of truth is Drizzle.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Org {
  slug              String   @id
  name              String
  category          String
  region            String?
  addisOffice       Boolean? @map("addis_office")

  website           String?
  careersUrl        String?  @map("careers_url")
  internshipUrl     String?  @map("internship_url")
  applicationEmail  String?  @map("application_email")

  twitter           String?
  linkedin          String?
  telegram          String?

  // 'yes' | 'no' | 'sometimes' | 'unknown'
  postsPublicly     String   @default("unknown") @map("posts_publicly")
  // 'yes' | 'no' | 'sometimes'
  hasRemote         String?  @map("has_remote")
  hasPaid           String?  @map("has_paid")

  // 'critical' | 'high' | 'medium' | 'low'
  scrapePriority    String?  @map("scrape_priority")

  notes             String?

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz

  listings          Listing[]

  @@index([category], map: "orgs_category_idx")
  @@index([postsPublicly], map: "orgs_posts_publicly_idx")
  @@index([scrapePriority], map: "orgs_scrape_priority_idx")
  @@map("orgs")
}

model Listing {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source           String
  sourceUrl        String    @map("source_url")
  sourceId         String?   @map("source_id")

  orgName          String    @map("org_name")
  orgSlug          String?   @map("org_slug")
  org              Org?      @relation(fields: [orgSlug], references: [slug], onDelete: SetNull)

  title            String
  location         String?
  isRemote         Boolean   @default(false) @map("is_remote")
  // null = unclear from the source; never invent.
  isPaid           Boolean?  @map("is_paid")
  stipendText      String?   @map("stipend_text")

  deadline         DateTime? @db.Timestamptz
  postedAt         DateTime? @map("posted_at") @db.Timestamptz
  scrapedAt        DateTime  @default(now()) @map("scraped_at") @db.Timestamptz

  descriptionHtml  String    @map("description_html")
  descriptionText  String    @map("description_text")

  fieldTags        String[]  @default([]) @map("field_tags")
  fitScore         Int       @default(0) @map("fit_score")

  // 'active' | 'expired' | 'hidden'
  status           String    @default("active")

  raw              Json?

  bookmarks        Bookmark[]
  reminders        Reminder[]

  @@unique([sourceUrl], map: "listings_source_url_unique")
  @@index([source], map: "listings_source_idx")
  @@index([deadline], map: "listings_deadline_idx")
  @@index([status], map: "listings_status_idx")
  @@index([fitScore], map: "listings_fit_score_idx")
  @@index([orgSlug], map: "listings_org_slug_idx")
  @@map("listings")
}

model Subscriber {
  chatId           BigInt   @id @map("chat_id")
  username         String?
  joinedAt         DateTime @default(now()) @map("joined_at") @db.Timestamptz
  // { fields: string[], paid_only: boolean, remote_ok: boolean }
  filters          Json     @default("{\"fields\":[],\"paid_only\":false,\"remote_ok\":true}")
  savedListingIds  String[] @default([]) @map("saved_listing_ids") @db.Uuid
  notify24h        Boolean  @default(true) @map("notify_24h")
  notify72h        Boolean  @default(true) @map("notify_72h")

  @@map("subscribers")
}

model ScrapeRun {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source       String
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz
  newCount     Int       @default(0) @map("new_count")
  updatedCount Int       @default(0) @map("updated_count")
  errorCount   Int       @default(0) @map("error_count")
  log          Json?

  @@index([source, startedAt], map: "scrape_runs_source_started_idx")
  @@map("scrape_runs")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  sessions   Session[]
  accounts   Account[]
  bookmarks  Bookmark[]
  reminders  Reminder[]

  @@unique([email], map: "user_email_unique")
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  token     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token], map: "session_token_unique")
  @@index([userId], map: "session_user_id_idx")
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@index([userId], map: "account_user_id_idx")
  @@index([providerId, accountId], map: "account_provider_idx")
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@index([identifier], map: "verification_identifier_idx")
  @@map("verification")
}

model Bookmark {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String   @map("listing_id") @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, listingId], map: "bookmarks_user_listing_idx")
  @@map("bookmarks")
}

model Reminder {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String   @map("listing_id") @db.Uuid
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  remindAt  DateTime @map("remind_at") @db.Timestamptz
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([userId, listingId], map: "reminders_user_listing_idx")
  @@map("reminders")
}
