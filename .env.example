# Copy to .env at the monorepo root. All apps read ONLY this file (loaded via
# vite envDir for the web app, --env-file / dotenv for bot and worker) —
# per-app .env files are ignored.

# Postgres connection string for Drizzle
DATABASE_URL=postgres://user:password@localhost:5432/internit

# --- Classification (Tier 2 LLM fallback) ---
# Provider auto-picks gemini when GEMINI_API_KEY is set, else anthropic.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# CLASSIFIER_PROVIDER=gemini            # or: anthropic
# CLASSIFIER_MODEL=gemini-2.5-flash-lite

# --- Structurer (cheap AI structuring of parsed listings) ---
STRUCTURER_ENABLED=false
STRUCTURER_PROVIDER=gemini
# flash over flash-lite: fewer high-demand 503s, better extraction; ~$5/mo at our volume.
STRUCTURER_MODEL=gemini-2.5-flash
STRUCTURER_BATCH_SIZE=5
# Paced ≤12/min by default (free-tier limits); paid tier can drop to ~1000.
# STRUCTURER_MIN_INTERVAL_MS=5000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Public bot @username (no @), used by the web app to build "remind me" deep links
PUBLIC_TELEGRAM_BOT_USERNAME=
# Your own Telegram chat id; gates dev-only bot commands (/test_card). Unset = disabled.
ADMIN_CHAT_ID=

# Public site URL. Used in channel posts ("Read" links) and in the scraper's
# User-Agent contact URL (SITE_URL/about).
SITE_URL=http://localhost:5173

# --- Worker (scrape pipeline) ---
# WORKER_CRON=0 12 * * *                # daily scrape schedule (server TZ)
# WORKER_CLEANUP_CRON=0 */3 * * *       # expire/prune pass
# WORKER_STEP_TIMEOUT_MS=1800000        # 30 min per pipeline step
# WORKER_HEALTHCHECK_URL=               # e.g. Healthchecks.io ping URL
# SCRAPER_IGNORE_ROBOTS=1               # dev escape hatch for local testing ONLY —
                                        # production scraping respects robots.txt

# --- Better Auth (web sign-in for bookmarks) ---
# Required — the app refuses to start without it: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Web server (prod, adapter-node) ---
# PORT the Node server binds; ORIGIN = public URL for CSRF/form-action checks
# (or set PROTOCOL_HEADER/HOST_HEADER behind a reverse proxy). In prod,
# BETTER_AUTH_URL must also be the real public URL.
PORT=3000
ORIGIN=http://localhost:3000

# ReliefWeb API appname (request at https://apidoc.reliefweb.int/parameters#appname)
RELIEFWEB_APPNAME=
