# Postgres connection string for Drizzle
DATABASE_URL=postgres://rue:rue@localhost:5432/rue

# Claude API key for Tier 2 classifier fallback
ANTHROPIC_API_KEY=

# Cheap AI structuring for parsed listings.
# Disabled unless STRUCTURER_ENABLED=true.
GEMINI_API_KEY=
STRUCTURER_ENABLED=false
STRUCTURER_PROVIDER=gemini
STRUCTURER_MODEL=gemini-2.5-flash-lite
STRUCTURER_MAX_INPUT_CHARS=12000
STRUCTURER_TIMEOUT_MS=90000
STRUCTURER_RETRIES=2
STRUCTURER_BATCH_SIZE=5

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Public bot @username (no @), used by the web app to build "remind me" deep links
PUBLIC_TELEGRAM_BOT_USERNAME=

# Public site URL the bot puts in channel posts (the "Read" → reader-mode link)
SITE_URL=http://localhost:5173

# Admin bearer for POST /api/scrape/trigger
ADMIN_TOKEN=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787
WEB_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web server (prod, adapter-node): PORT the Node server binds, ORIGIN = public
# URL for CSRF/form-action checks (or set PROTOCOL_HEADER/HOST_HEADER behind a
# reverse proxy). In prod, BETTER_AUTH_URL + WEB_ORIGIN must also be the real URL.
PORT=3000
ORIGIN=http://localhost:3000

# API base url used by web client
VITE_API_URL=http://localhost:8787

# ReliefWeb API appname (request at https://apidoc.reliefweb.int/parameters#appname)
RELIEFWEB_APPNAME=
